{
  "name": "html-live-edit",
  "displayName": "HTML Live Edit",
  "description": "Visual WYSIWYG editor for HTML files - double-click text to edit, source view, undo/redo, zoom, image replacement",
  "version": "1.1.0",
  "publisher": "xjb",
  "repository": {
    "type": "git",
    "url": "https://github.com/JunbiaoXue/html-live-edit.git"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "html",
    "wysiwyg",
    "visual editor",
    "live edit",
    "preview"
  ],
  "activationEvents": [
    "onCustomEditor:htmlWysiwyg.editor"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "htmlWysiwyg.editor",
        "displayName": "HTML Visual Editor",
        "selector": [
          {
            "filenamePattern": "*.html"
          },
          {
            "filenamePattern": "*.htm"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "htmlWysiwyg.openEditor",
        "title": "Open HTML Visual Editor",
        "category": "HTML Editor",
        "icon": "media/icon.png"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "htmlWysiwyg.openEditor",
          "when": "resourceExtname == .html || resourceExtname == .htm",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "htmlWysiwyg.openEditor",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "resourceExtname == .html || resourceExtname == .htm"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^2.0.0",
    "typescript": "^5.3.0"
  }
}
